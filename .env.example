# imocerto backend REST API this server proxies to.
IMOCERTO_API_BASE_URL=http://localhost:8787/api

# Public base URL of THIS server (the OAuth issuer). For local use, leave as is.
PUBLIC_URL=http://localhost:8080
PORT=8080

# MUST match the backend's JWT_SECRET so this server can verify access tokens.
IMOCERTO_JWT_SECRET=

# Frontend entry for the login + consent UI (the imocerto Next app). Locale-less:
# the app resolves the user's language and forwards to the localized page.
FRONTEND_CONSENT_URL=http://localhost:3000/oauth-consent

# Where registered OAuth clients are persisted so they survive restarts.
OAUTH_CLIENTS_PATH=./data/oauth-clients.json
