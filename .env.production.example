# Copy to .env.production on the server. Never commit the real file.

PORT=8080

# Public HTTPS URL of THIS server (the OAuth issuer). Must match the domain in
# the Caddyfile.
PUBLIC_URL=https://mcp.zyro.example

# The imocerto BE, reached over the Hetzner PRIVATE network — not its public
# domain. This is what lets us skip poking a hole in the BE's firewall.
IMOCERTO_API_BASE_URL=http://10.0.0.X:8787/api

# The backend's RS256 PUBLIC key (PEM, \n-escaped on one line). Verify-only, so
# a breach of this server cannot forge tokens against the BE.
IMOCERTO_JWT_PUBLIC_KEY=

# The FE consent page users are redirected to during OAuth.
FRONTEND_CONSENT_URL=https://app.zyro.example/oauth-consent

# Persisted OAuth client registrations (mounted volume — survives redeploys).
OAUTH_CLIENTS_PATH=/app/data/oauth-clients.json
