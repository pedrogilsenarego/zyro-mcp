# Copy to .env.production on the server. Never commit the real file.

PORT=8080

# Public HTTPS URL of THIS server (the OAuth issuer). Must match the Caddyfile.
PUBLIC_URL=https://mcp.zyr-o.app

# The imocerto BE. CORS-only block, so the public URL works server-to-server.
IMOCERTO_API_BASE_URL=https://api.zyr-o.app/api

# The backend's RS256 PUBLIC key (PEM, \n-escaped on one line) — the SAME value
# as the BE's JWT_PUBLIC_KEY. Verify-only: a breach here can't forge tokens.
IMOCERTO_JWT_PUBLIC_KEY=

# The FE consent page users are redirected to during OAuth.
FRONTEND_CONSENT_URL=https://zyr-o.app/oauth-consent

# Persisted OAuth client registrations (mounted volume — survives redeploys).
OAUTH_CLIENTS_PATH=/app/data/oauth-clients.json
