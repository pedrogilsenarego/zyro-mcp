# Copy to .env.test and fill in to run the opt-in contract tests:
#   pnpm test:contract
# Without these, `pnpm test` skips the contract tests (unit tests still run).

# Your imocerto access-token JWT (expires ~1h — refresh if you get a 401).
IMOCERTO_TEST_TOKEN=

# The user id whose listings the contract test reads.
IMOCERTO_TEST_USER_ID=aa6e7e00-1f1d-4adf-864f-c947d599fde4

# The running backend's /api root.
IMOCERTO_API_BASE_URL=http://localhost:8787/api
